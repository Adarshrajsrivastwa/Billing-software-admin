NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/billing_software?retryWrites=true&w=majority

# JWT secrets — use long random strings in production (min 32 chars)
JWT_ACCESS_SECRET=change_this_access_secret_min_32_characters_long
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# Cookie settings
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
